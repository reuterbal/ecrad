# -------------------------------------------------------------------
# Loki source transformation configurations
# -------------------------------------------------------------------
# This file contains configurations for multiple source transformation
# pipelines and batch processing settings to apply Loki transformations
# to the ecrad source tree.


# Loki batch scheduler configuration
# -------------------------------------------------------------------
# The Loki batch scheduler performs automated discovery of call trees
# from a select set of seed subroutines. Whenever it adds new
# nodes to the call tree, the following default behaviour will be
# honoured, unless it is specifically overwritten below.

[default]
role = 'kernel'  # Role to determine how to transform a routine
expand = true  # Automatically expand call tree to subroutine calls
strict = true  # Throw exceptions during dicovery
enable_imports = true  # Chase dependencies incurred via imports

# Ensure that we are never adding these to the tree, and thus
# do not attempt to look up the source files for these.
disable = [
  'fast_expm_exchange', 'date_and_time', 'get_command',
  'rng_type', 'radiation_reverse', 'yomhook', 'netcdf', 'ec_lun',
  '*get_host_data_*', '*get_view', '*get_device_data_*', 'get_stack_member',
  '*sync_host*', '*sync_device*', 'field_new', 'field_delete',
  '*create_device*', '*delete_device*', '*update_host*', '*update_device*',
  'field_access_module', 'sget_device*', 'sget_host*',
  'setup_gas_optics',
  'abor1', 'dr_hook', 'radiation_abort',
  # Radiation field types
  'radintg_zrgp_mod',
  'radiation_field_type_mod*',
  # ecRad derived types member routines
  'radiation_gas#gas_type%allocate',
  'radiation_gas#gas_type%deallocate',
  'radiation_gas#gas_type%put',
  'radiation_gas#gas_type%scale',
  'radiation_gas#gas_type%reverse',
  'radiation_gas#gas_type%out_of_physical_bounds',
  'radiation_single_level#single_level_type%allocate',
  'radiation_single_level#single_level_type%deallocate',
  'radiation_single_level#single_level_type%init_seed_simple',
  'radiation_single_level#single_level_type%out_of_physical_bounds',
  'radiation_cloud#cloud_type%allocate',
  'radiation_cloud#cloud_type%deallocate',
  'radiation_cloud#cloud_type%set_overlap_param_approx',
  'radiation_cloud#cloud_type%create_fractional_std',
  'radiation_cloud#cloud_type%create_inv_cloud_effective_size',
  'radiation_cloud#cloud_type%create_inv_cloud_effective_size_eta',
  'radiation_cloud#cloud_type%out_of_physical_bounds',
  'radiation_flux#flux_type%out_of_physical_bounds',
  'radiation_flux#flux_type%heating_rate_out_of_physical_bounds',
  'radiation_thermodynamics#thermodynamics_type%allocate',
  'radiation_thermodynamics#thermodynamics_type%deallocate',
  'radiation_thermodynamics#thermodynamics_type%get_layer_mass_column',
  'radiation_thermodynamics#thermodynamics_type%out_of_physical_bounds',
  # Disable processing of setup and save method in cloud optics
  'radiation_general_cloud_optics_data#setup_general_cloud_optics',
  'radiation_general_cloud_optics_data#save_general_cloud_optics_data',
  # Disable processing of the other gas_optics apart from ecckd
  'radiation_monochromatic', 'radiation_ifs_rrtm',
  # however we don't to process the setup/config routines:
  'save_radiative_properties', 'radiaton_config', 'radiation_setup',
  'radiation_ecckd_interface#setup_gas_optics', 
  'radiation_spartacus_sw', 'radiation_spartacus_lw', 'radiation_mcica_sw',
  'radiation_mcica_lw', 'radiation_cloudless_sw', 'radiation_cloudless_lw',
  'radiation_homogeneous_sw', 'radiation_homogeneous_lw', 'radiation_save'
]

# Prune these modules from the tree to ensure they are not processed by
# transformations
ignore = ['parkind1', 'easy_netcdf', 'field_module', 'mpl_module', 'field_factory_module',
          'radiation_aerosol',
          # radiation_thermodynamics contains routines called inside ecrad and must be loki processed
          # radiation_single_level contains routines called inside ecrad and must be loki processed
          # radiation_flux contains routines called inside ecrad and must be loki processed
          # radiation_cloud contains routines called inside ecrad and must be loki processed
]


# Frontend argument overrides
# -------------------------------------------------------------------
# Certain modules hard depend on preprocessing
[frontend_args]

[frontend_args."radiation_scheme_layer_mod.F90"]
  preprocess = true

[frontend_args."radiation_random_numbers.F90"]
  preprocess = true

[frontend_args."radiation_spartacus_sw.F90"]
  preprocess = true

[frontend_args."radiation_two_stream.F90"]
  preprocess = true

[frontend_args."radiation_scheme.F90"]
  preprocess = true

[frontend_args."radiation_config.F90"]
  preprocess = true

[frontend_args."radiation_cloud_optics_data.F90"]
  preprocess = true

[frontend_args."radiation_aerosol_optics_data.F90"]
  preprocess = true

# Call tree entry points ("driver" subroutines)
# -------------------------------------------------------------------
#
# Note that Loki differentiates between "driver" routines, which act as
# call tree roots and contain the offload and parallelisation loops, and
# "kernel" routines that only contain compute loops and are called
# from drivers or other kernels within parallel sections.
[routines]

[routines.radiation_scheme_layer_loki]
  role = 'driver'
  expand = true

[routines.RADIATION_SCHEME]
  role = 'kernel'
  ignore = ['save_inputs', 'save_fluxes', 'MPL_MYRANK']

# Configuration of "Dimension" variables
# -------------------------------------------------------------------
# Loki uses rigorously enforced variable naming conventions to
# identifiy loops that pertain to a particular scientific dimension.
[dimensions]

# The horizontal dimension that signifies the vecotr dimension
[dimensions.horizontal]
  size = ['ncol', 'klon']
  index = 'jcol'
  lower = ['kidia', 'istartcol']
  upper = ['kfdia', 'iendcol']

# The vertical data dimension for advanced optimisations
[dimensions.vertical]
  size = ['nlev', 'klev']
  index = 'jlev'

# The outer loop blocking dimension in the parallel driver
[dimensions.block_dim]
  size = 'ngpblks'
  index = 'ibl'


# Define specific transformation settings
# -------------------------------------------------------------------
# The section configures the invididual steps of the transformation
# pipelines. Importantly, it also defines the class name and Python
# module that Transformation objects will be instatiated from.
[transformations]

# A set of utility transformations
# -------------------------------------------------------------------
[transformations.Idem]
  classname = 'IdemTransformation'
  module = 'loki.transformations'

[transformations.RemoveCode]
  classname = 'RemoveCodeTransformation'
  module = 'loki.transformations'
[transformations.RemoveCode.options]
  remove_marked_regions = true
  remove_dead_code = false
  kernel_only = true
  call_names = ['ABOR1', 'DR_HOOK', 'radiation_abort']
  intrinsic_names = ['WRITE(NULOUT', 'WRITE(CLERROR', 'WRITE(NULERR', 'WRITE(*']

[transformations.Inline]
  classname = 'InlineTransformation'
  module = 'loki.transformations'
[transformations.Inline.options]
  inline_internals = false
  inline_marked = true
  inline_stmt_funcs = false
  remove_dead_code = false
  # allowed_aliases = 'JL'
  resolve_sequence_association = false


# Housekeeping and other transformations
# -------------------------------------------------------------------
[transformations.Sanitise]
  classname = 'SanitiseTransformation'
  module = 'loki.transformations'
  options = { resolve_associate_mappings = true }

[transformations.FileWriteTransformation]
  classname = 'FileWriteTransformation'
  module = 'loki.transformations'
  options = { include_module_var_imports = true }

[transformations.TypeboundProcedure]
  classname = 'TypeboundProcedureCallTransformation'
  module = 'loki.transformations'
  options = { nopass = true }

# Loki-SCC family of transformations
# -------------------------------------------------------------------
# A set of transformation passes that transforms SIMD vectorisation
# loops into SIMD-style loops for coalesced memory access on GPU.
# It also contains passes that improve device memory handling on GPUs.

[transformations.SCCVector]
  classname = 'SCCVectorPipeline'
  module = 'loki.transformations.single_column'
[transformations.SCCVector.options]
  horizontal = '%dimensions.horizontal%'
  block_dim = '%dimensions.block_dim%'
  directive = 'openacc'
  trim_vector_sections = true

# Full transformation pipelines
# -------------------------------------------------------------------
# The entries below are mapped to the "mode" entry point in
# loki-transform.py. The define the set of transformation and the
# order in which they are applies to the complete call tree.
[pipelines]

[pipelines.idem]
  transformations = ['Idem']

[pipelines.remove_code]
  transformations = ['RemoveCode']

[pipelines.preprocess]
  transformations = ['RemoveCode', 'TypeboundProcedure']

[pipelines.scc]
  transformations = ['RemoveCode', 'TypeboundProcedure', 'Inline', 'SCCVector']
